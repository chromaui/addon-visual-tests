    "buildCommand": "yarn tsc --noEmit 2>&1 | grep -E \"src/utils/requestAccessToken|src/utils/graphQLClient|src/utils/oauthGrant|src/screens/Authentication/Verify|src/Panel\\.tsx|src/screens/ShareSection/useShareAuth\" | head -20",
